{
    "name": "@likemex/fs-react-lib",
    "version": "0.9.0",
    "description": "Shared FS AI assistant chat widget (REST + SSE) for FutureSkill Next.js apps",
    "license": "MIT",
    "author": "LikeMeX",
    "repository": {
        "type": "git",
        "url": "https://github.com/LikeMeX/fs-react-lib"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=24"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./tailwind-tokens": "./tailwind-tokens.js",
        "./tailwind-preset": "./tailwind-preset.js",
        "./colors": "./colors.js"
    },
    "files": [
        "dist",
        "tailwind-tokens.js",
        "README.md",
        "colors.js",
        "tailwind-preset.js",
        "index.js",
        "LICENSE"
    ],
    "scripts": {
        "build": "rm -rf dist && tsc -p tsconfig.build.json",
        "lint": "tsc -p tsconfig.build.json --noEmit",
        "test": "jest",
        "prepublishOnly": "npm run build"
    },
    "pnpm": {
        "neverBuiltDependencies": [
            "canvas"
        ]
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "peerDependencies": {
        "@ant-design/cssinjs": "^1.0.0",
        "@tanstack/react-query": "^4.0.0",
        "antd": "^5.0.0",
        "axios": ">=0.24.0",
        "next": "^12.0.0 || ^13.0.0 || ^14.0.0",
        "react": "^17.0.0 || ^18.0.0",
        "react-dom": "^17.0.0 || ^18.0.0",
        "react-icons": "^4.0.0 || ^5.0.0",
        "react-markdown": "^7.0.0 || ^8.0.0",
        "rehype-katex": "^6.0.0 || ^7.0.0",
        "remark-gfm": "^3.0.0 || ^4.0.0",
        "remark-math": "^5.0.0 || ^6.0.0"
    },
    "devDependencies": {
        "@ant-design/cssinjs": "^1.23.0",
        "@tanstack/react-query": "^4.36.1",
        "@testing-library/jest-dom": "^6",
        "@testing-library/react": "^14.3.1",
        "@types/jest": "^29",
        "@types/katex": "^0.16.8",
        "@types/node": "^20.0.0",
        "@types/react": "^18.3.31",
        "@types/react-dom": "^18.3.7",
        "antd": "^5.23.4",
        "axios": "^1.7.0",
        "jest": "^29",
        "jest-environment-jsdom": "^29",
        "katex": "^0.17.0",
        "next": "^12.3.4",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-icons": "^5.4.0",
        "react-markdown": "^8.0.7",
        "rehype-katex": "6",
        "remark-gfm": "^3.0.1",
        "remark-math": "5",
        "ts-jest": "^29",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.0"
    }
}